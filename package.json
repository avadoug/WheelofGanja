{
  "name": "the-great-ganja-spin",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/build-sites-worker.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "start": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "validate:puzzles": "node --experimental-strip-types scripts/validate-puzzles.ts",
    "simulate:match": "node --experimental-strip-types scripts/simulate-match.ts",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "check": "tsc --noEmit && npm run lint && npm run test"
  },
  "dependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.55.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "7.0.1",
    "globals": "16.5.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.53.0",
    "vite": "8.0.13",
    "vitest": "3.2.4"
  },
  "type": "module"
}
